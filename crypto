      appState.datasetName = datasetName || normalized.metadata?.datasetName || 'Loaded dataset';
      appState.warnings = normalized.warnings;
      appState.currentAnnotationFallback = {
        label: normalized.points[0]?.label || 'Start',
        text: normalized.points[0]?.event || 'Dataset loaded.'
      };

      titleEl.textContent = normalized.metadata.title || 'Crypto Market Cap Dominance Race';
      subtitleEl.textContent = normalized.metadata.subtitle || 'Top 10 cryptocurrencies by market cap from a monthly dataset. Values shown in USD billions.';
      sourcesLineEl.textContent = normalized.metadata.sourceLine || 'Sources: Custom monthly dataset loaded. Values shown in USD billions. · CryptoShorts';

      scrubber.max = String(Math.max(0, appState.frames.length - 1));
      currentIndex = 0;
      frameAccumulator = 0;
      updateFrame(0);

      const months = normalized.points.length;
      const coins = Object.keys(appState.seriesByCoin).length;
      datasetNameEl.textContent = appState.datasetName;
      datasetDetailEl.textContent = `${months} monthly records · ${coins} coins seen · ${appState.subframes} subframes between months${normalized.warnings.length ? ' · ' + normalized.warnings.join(' · ') : ''}`;
      updateStatus('Loaded', 'ok', datasetDetailEl.textContent);
    }

    function normalizeDataset(raw) {
      const metadata = raw && typeof raw === 'object' && !Array.isArray(raw) ? (raw.metadata || {}) : {};
      let coinMeta = raw && typeof raw === 'object' && !Array.isArray(raw) ? (raw.coins || {}) : {};
      let warnings = [];
      let points = [];

      if (Array.isArray(raw)) {
        points = normalizeRecordsArray(raw);
      } else if (raw && Array.isArray(raw.records)) {
        points = normalizeRecordsArray(raw.records);
      } else if (raw && Array.isArray(raw.data)) {
        points = normalizeRecordsArray(raw.data);
      } else if (raw && raw.series && Array.isArray(raw.series)) {
        points = normalizeSeriesObject(raw.series, raw.annotations || []);
      } else {
        throw new Error('Unsupported dataset structure. Use JSON records/series or CSV wide/long format.');
      }

      if (!points.length) throw new Error('Dataset contains no valid monthly rows.');
      points.sort((a, b) => a.dateObj - b.dateObj);

      const unique = [];
      const seen = new Map();
      for (const point of points) {
        const key = point.dateKey;
        if (!seen.has(key)) {
          seen.set(key, { ...point });
          unique.push(seen.get(key));
        } else {
          const existing = seen.get(key);
          existing.caps = { ...existing.caps, ...point.caps };
          existing.event = existing.event || point.event;
        }
      }
      points = unique.map(p => ({
        ...p,
        label: p.dateObj.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
      }));

      let previousMonthIndex = null;
      for (const point of points) {
        const idx = point.dateObj.getUTCFullYear() * 12 + point.dateObj.getUTCMonth();
        if (previousMonthIndex != null && idx - previousMonthIndex > 1) {
          warnings.push(`missing ${idx - previousMonthIndex - 1} month(s) between ${points.find(x => x.dateObj.getUTCFullYear()*12+x.dateObj.getUTCMonth()===previousMonthIndex)?.label || 'records'}`);
        }
        previousMonthIndex = idx;
      }
      if (warnings.length > 2) warnings = [warnings[0], `${warnings.length - 1} more month-gap warning(s)`];

      const subframes = Math.max(0, Number(QUERY_SUBFRAMES || metadata.subframes || 4));

      return { metadata, coinMeta, points, subframes, warnings };
    }

    function normalizeRecordsArray(records) {
      if (!records.length) return [];
      const first = records[0];
      if (first && typeof first === 'object' && 'caps' in first) {
        return records.map(r => ({
          dateObj: normalizeMonth(r.date),
          dateKey: monthKey(normalizeMonth(r.date)),
          caps: normalizeCapsObject(r.caps),
          event: r.event || r.annotation || null
        }));
      }
      if (first && typeof first === 'object' && ('symbol' in first || 'market_cap_b' in first || 'marketCapB' in first)) {
        return longRowsToPoints(records);
      }
      if (first && typeof first === 'object' && 'date' in first) {
        return wideRowsToPoints(records);
      }
      throw new Error('Could not detect record structure.');
    }

    function normalizeSeriesObject(series, annotations) {
      const byMonth = new Map();
      for (const item of series) {
        const symbol = String(item.symbol || '').trim().toUpperCase();
        if (!symbol || !Array.isArray(item.points)) continue;
        if (item.name || item.color || item.logo) {
          BUILTIN_COINS[symbol] = { ...(BUILTIN_COINS[symbol] || { name: symbol, color: '#4f6b95', logo: '' }), ...(item.name ? { name: item.name } : {}), ...(item.color ? { color: item.color } : {}), ...(item.logo ? { logo: item.logo } : {}) };
        }
        for (const p of item.points) {
          const d = normalizeMonth(p.date);
          const key = monthKey(d);
          if (!byMonth.has(key)) byMonth.set(key, { dateObj: d, dateKey: key, caps: {}, event: null });
          byMonth.get(key).caps[symbol] = normalizeNumber(p.market_cap_b ?? p.marketCapB ?? p.value ?? 0);
        }
      }
      for (const ann of annotations || []) {
        const d = normalizeMonth(ann.date);
        const key = monthKey(d);
        if (!byMonth.has(key)) byMonth.set(key, { dateObj: d, dateKey: key, caps: {}, event: null });
        byMonth.get(key).event = ann.event || ann.text || byMonth.get(key).event;
      }
      return Array.from(byMonth.values());
    }

    function wideRowsToPoints(rows) {
      return rows.map(row => {
        const caps = {};
        for (const [key, value] of Object.entries(row)) {
          if (['date','month','event','annotation','note'].includes(key.toLowerCase())) continue;
          const symbol = String(key).trim().toUpperCase();
          const num = normalizeNumber(value);
          if (Number.isFinite(num) && num > 0) caps[symbol] = num;
        }
        const dateObj = normalizeMonth(row.date || row.month);
        return {
          dateObj,
          dateKey: monthKey(dateObj),
          caps,
          event: row.event || row.annotation || row.note || null
        };
      });
    }

    function longRowsToPoints(rows) {
      const byMonth = new Map();
      for (const row of rows) {
        const dateObj = normalizeMonth(row.date || row.month);
        const key = monthKey(dateObj);
        if (!byMonth.has(key)) byMonth.set(key, { dateObj, dateKey: key, caps: {}, event: null });
        const symbol = String(row.symbol || row.coin || row.ticker || '').trim().toUpperCase();
        if (!symbol) continue;
        const num = normalizeNumber(row.market_cap_b ?? row.marketCapB ?? row.market_cap ?? row.value ?? 0);
        if (Number.isFinite(num) && num > 0) byMonth.get(key).caps[symbol] = num;
        if (row.event || row.annotation || row.note) byMonth.get(key).event = row.event || row.annotation || row.note;
      }
      return Array.from(byMonth.values());
    }

    function buildSeriesByCoin(points) {
      const symbols = Array.from(new Set(points.flatMap(p => Object.keys(p.caps))));
      const series = {};
      for (const symbol of symbols) {
        series[symbol] = points.map(p => p.caps[symbol] || 0);
      }
      return series;
    }

    function buildFramesFromMonthly(points, subframes) {
      const out = [];
      for (let i = 0; i < points.length - 1; i++) {
        const a = points[i];
        const b = points[i + 1];
        const symbols = Array.from(new Set([...Object.keys(a.caps), ...Object.keys(b.caps)]));
        const steps = Math.max(1, subframes + 1);
        for (let s = 0; s < steps; s++) {
          const t = s / steps;
          const caps = {};
          for (const symbol of symbols) {
            const av = a.caps[symbol] || 0;
            const bv = b.caps[symbol] || 0;
            caps[symbol] = lerp(av, bv, easeInOutCubic(t));
          }
          out.push({
            caps,
            dateObj: new Date(a.dateObj.getTime() + (b.dateObj.getTime() - a.dateObj.getTime()) * t),
            annotation: a.event || null,
            annotationLabel: a.label,
            monthlyIndex: i,
            exactMonth: s === 0
          });
        }
      }
      const last = points[points.length - 1];
      out.push({
        caps: { ...last.caps },
        dateObj: new Date(last.dateObj),
        annotation: last.event || null,
        annotationLabel: last.label,
        monthlyIndex: points.length - 1,
        exactMonth: true
      });
      return out;
    }

    function initRows() {
      if (rowRefs.length) return;
      for (let i = 0; i < 10; i++) {
        const row = document.createElement('div');
        row.className = 'row';
        row.innerHTML = `
          <div class="rank">
            <div class="logo-wrap rank-logo-wrap">
              <div class="logo-fallback">?</div>
              <img class="logo-img" alt="" />
            </div>
          </div>
          <div class="bar-shell">
            <div class="bar" style="width:0%; background:#22344d;">
              <div class="bar-content">
                <div class="coin-meta">
                  <div class="logo-wrap">
                    <div class="logo-fallback">?</div>
                    <img class="logo-img" alt="" />
                  </div>
                  <div class="coin-name">
                    <div class="symbol">-</div>
                    <div class="label">-</div>
                  </div>
                </div>
                <div class="share">0.0%</div>
              </div>
            </div>
          </div>
          <div class="value">$0B</div>
          <div class="spark-wrap"><canvas></canvas></div>
        `;
        rowsEl.appendChild(row);
        const logoFallbacks = row.querySelectorAll('.logo-fallback');
        const logoImgs = row.querySelectorAll('.logo-img');
        const refs = {
          root: row,
          bar: row.querySelector('.bar'),
          rankFallback: logoFallbacks[0],
          rankImg: logoImgs[0],
          fallback: logoFallbacks[1],
          img: logoImgs[1],
          symbol: row.querySelector('.symbol'),
          label: row.querySelector('.label'),
          share: row.querySelector('.share'),
          value: row.querySelector('.value'),
          sparkCanvas: row.querySelector('canvas'),
          currentSymbol: null
        };
        rowRefs.push(refs);
        sparkCharts.set(refs.sparkCanvas, createSparkChart(refs.sparkCanvas));
      }
    }

    function updateFrame(index) {
      const frame = appState.frames[index];
      if (!frame) return;
      scrubber.value = String(index);
      const ranked = Object.entries(frame.caps)
        .map(([symbol, value]) => ({ symbol, value }))
        .filter(item => item.value > 0.0000001)
        .sort((a, b) => b.value - a.value)
        .slice(0, 10);

      const leader = ranked[0]?.value || 1;
      const total = ranked.reduce((sum, d) => sum + d.value, 0);
      const fullDate = frame.dateObj.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
      dateEl.textContent = fullDate;
      totalEl.textContent = `Top 10 total: ${formatBillions(total)}`;

      const annotation = getActiveAnnotation(index);
      eventDateEl.textContent = annotation.label;
      eventTextEl.textContent = annotation.text;

      for (let i = 0; i < rowRefs.length; i++) {
        const row = rowRefs[i];
        const item = ranked[i];
        if (!item) {
          row.root.style.opacity = '0';
          continue;
        }
        row.root.style.opacity = '1';
        const meta = appState.coinMeta[item.symbol] || { name: item.symbol, color: '#4f6b95', logo: '' };
        const pctOfLeader = Math.max(0.6, (item.value / leader) * 100);
        const share = total > 0 ? (item.value / total) * 100 : 0;
        row.bar.style.width = `${pctOfLeader}%`;
        row.bar.style.background = `linear-gradient(90deg, ${hexToRgba(meta.color || '#4f6b95', 0.95)}, ${hexToRgba(meta.color || '#4f6b95', 0.70)})`;
        row.symbol.textContent = item.symbol;
        row.label.textContent = meta.name || item.symbol;
        row.share.textContent = `${share.toFixed(1)}%`;
        row.value.textContent = formatBillions(item.value);
        row.fallback.textContent = item.symbol.slice(0, 3);
        row.fallback.style.background = meta.color || '#4f6b95';
        row.rankFallback.textContent = item.symbol.slice(0, 3);
        row.rankFallback.style.background = meta.color || '#4f6b95';
        if (row.currentSymbol !== item.symbol) {
          row.currentSymbol = item.symbol;
          updateLogo(row, meta.logo);
        }
        updateSparkline(row.sparkCanvas, item.symbol, frame.monthlyIndex, meta.color || '#4f6b95');
      }
      updateSocialOverlay(index, frame, ranked, total);
      drawWatermark();
    }

    function updateSocialOverlay(index, frame, ranked, total) {
      if (!SOCIAL_MODE) return;
      const p = index / Math.max(1, appState.frames.length - 1);
      let kicker = 'Dominance War';
      let text = 'Every “next Bitcoin” failed.';
      let sub = 'True monthly market-cap data in, viral cut out.';
      if (p < 0.12) {
        kicker = 'Phase 1';
        text = 'They said it was early.';
        sub = 'Bitcoin dominates. A few challengers appear. Almost nobody understands what comes next.';
      } else if (p < 0.32) {
        kicker = 'Phase 2';
        text = 'Everything looked like a winner.';
        sub = 'Alt narratives flood the tape. Euphoria kills judgment.';
      } else if (p < 0.48) {
        kicker = 'Phase 3';
        text = 'Until it wasn’t.';
        sub = 'Market structure punishes every lazy thesis.';
      } else if (p < 0.72) {
        kicker = 'Phase 4';
        text = 'Real money entered.';
        sub = 'Institutions, ETFs, and stablecoins change the board.';
      } else if (p < 0.93) {
        kicker = 'Phase 5';
        text = 'Nothing replaced Bitcoin.';
        sub = 'Rotation happened. Narratives changed. The center of gravity did not.';
      } else {
        kicker = 'Now';
        text = 'Watch the structure, not the hype.';
        sub = `Top 10 total: ${formatBillions(total)}. Replay the cycle. The symbols change. Power persists.`;
      }
      hookKickerEl.textContent = kicker;
      hookTextEl.textContent = text;
      hookSubEl.textContent = sub;
      socialFooterEl.textContent = p > 0.96 ? 'Watch again' : 'CryptoShorts';
    }

    function getActiveAnnotation(frameIndex) {
      for (let i = frameIndex; i >= 0; i--) {
        const key = appState.frames[i];
        if (key && key.annotation) return { label: key.annotationLabel, text: key.annotation };
      }
      return appState.currentAnnotationFallback;
    }

    function updateLogo(refs, url) {
      for (const el of [refs.img, refs.rankImg]) {
        el.classList.remove('loaded');
        el.removeAttribute('src');
      }
      if (!url) return;
      const img = new Image();
      img.crossOrigin = 'anonymous';
      img.onload = () => {
        for (const el of [refs.img, refs.rankImg]) {
          el.src = url;
          el.classList.add('loaded');
        }
      };
      img.onerror = () => {
        for (const el of [refs.img, refs.rankImg]) {
          el.removeAttribute('src');
          el.classList.remove('loaded');
        }
      };
      img.src = url;
    }

    function createSparkChart(canvas) {
      return new Chart(canvas.getContext('2d'), {
        type: 'line',
        data: { labels: [], datasets: [{ data: [], borderColor: '#fff', borderWidth: 2, pointRadius: 0, tension: 0.34, fill: false }] },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          animation: false,
          plugins: { legend: { display: false }, tooltip: { enabled: false } },
          scales: { x: { display: false }, y: { display: false } },
          elements: { line: { capBezierPoints: true } }
        }
      });
    }

    function updateSparkline(canvas, symbol, monthlyIndex, color) {
      const chart = sparkCharts.get(canvas);
      if (!chart) return;
      const sampled = sampleSeries(symbol, monthlyIndex, 32);
      chart.data.labels = sampled.map((_, i) => i + 1);
      chart.data.datasets[0].data = sampled;
      chart.data.datasets[0].borderColor = color;
      chart.update('none');
    }

    function sampleSeries(symbol, monthlyIndex, points) {
      const series = appState.seriesByCoin[symbol] || [];
      const arr = [];
      const maxIndex = Math.max(1, monthlyIndex);
      if (!series.length) return new Array(points).fill(0);
      if (maxIndex <= points) {
        for (let i = 0; i <= maxIndex; i++) arr.push(series[i] || 0);
        while (arr.length < points) arr.unshift(arr[0] || 0);
        return arr;
      }
      for (let i = 0; i < points; i++) {
        const idx = Math.round((i / (points - 1)) * maxIndex);
        arr.push(series[idx] || 0);
      }
      return arr;
    }

    function loop(ts) {
      if (lastTs == null) lastTs = ts;
      const delta = ts - lastTs;
      lastTs = ts;
      if (playing) {
        frameAccumulator += delta * Number(speedSelect.value);
        while (frameAccumulator >= FRAME_MS) {
          frameAccumulator -= FRAME_MS;
          currentIndex += 1;
          if (currentIndex >= appState.frames.length) {
            if (LOOP_MODE) currentIndex = 0;
            else { currentIndex = appState.frames.length - 1; playing = false; break; }
          }
          updateFrame(currentIndex);
        }
      }
      requestAnimationFrame(loop);
    }

    function drawWatermark() {
      const rect = watermarkCanvas.getBoundingClientRect();
      watermarkCanvas.width = Math.max(1, rect.width * devicePixelRatio);
      watermarkCanvas.height = Math.max(1, rect.height * devicePixelRatio);
      watermarkCtx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
      watermarkCtx.clearRect(0, 0, rect.width, rect.height);
      const text = 'CryptoShorts';
      let fontSize = 400;
      watermarkCtx.font = `900 ${fontSize}px Inter, Arial, sans-serif`;
      while (watermarkCtx.measureText(text).width > rect.width * 0.92 && fontSize > 40) {
        fontSize -= 4;
        watermarkCtx.font = `900 ${fontSize}px Inter, Arial, sans-serif`;
      }
      watermarkCtx.save();
      watermarkCtx.translate(rect.width / 2, rect.height / 2);
      watermarkCtx.rotate(-25 * Math.PI / 180);
      watermarkCtx.textAlign = 'center';
      watermarkCtx.textBaseline = 'middle';
      watermarkCtx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--watermark').trim() || 'rgba(255,255,255,0.09)';
      watermarkCtx.fillText(text, 0, 0);
      watermarkCtx.restore();
    }

    function updateStatus(text, type, detail) {
      datasetStatusEl.textContent = text;
      datasetStatusEl.className = `dataset-status ${type}`;
      if (detail) datasetDetailEl.textContent = detail;
    }

    function showError(err) {
      console.error(err);
      updateStatus('Error', 'error', err.message || String(err));
      datasetNameEl.textContent = 'Dataset load failed';
      eventDateEl.textContent = 'Error';
      eventTextEl.textContent = err.message || String(err);
    }

    function parseCSV(text) {
      const lines = text.replace(/^\uFEFF/, '').split(/\r?\n/).filter(line => line.trim().length);
      if (!lines.length) throw new Error('CSV file is empty.');
      const header = parseCSVLine(lines[0]);
      return lines.slice(1).map(line => {
        const values = parseCSVLine(line);
        const obj = {};
        header.forEach((key, idx) => { obj[key] = values[idx] ?? ''; });
        return obj;
      });
    }

    function parseCSVLine(line) {
      const out = [];
      let current = '';
      let inQuotes = false;
      for (let i = 0; i < line.length; i++) {
        const ch = line[i];
        if (ch === '"') {
          if (inQuotes && line[i + 1] === '"') { current += '"'; i++; }
          else inQuotes = !inQuotes;
        } else if (ch === ',' && !inQuotes) {
          out.push(current);
          current = '';
        } else {
          current += ch;
        }
      }
      out.push(current);
      return out.map(v => v.trim());
    }

    function normalizeCapsObject(obj) {
      const out = {};
      for (const [symbol, value] of Object.entries(obj || {})) {
        const num = normalizeNumber(value);
        if (Number.isFinite(num) && num > 0) out[String(symbol).trim().toUpperCase()] = num;
      }
      return out;
    }

    function normalizeNumber(value) {
      if (typeof value === 'number') return value;
      if (value == null) return 0;
      const cleaned = String(value).replace(/\$/g, '').replace(/B\b/gi, '').replace(/,/g, '').trim();
      const num = Number(cleaned);
      return Number.isFinite(num) ? num : 0;
    }

    function normalizeMonth(value) {
      if (value instanceof Date) return new Date(Date.UTC(value.getUTCFullYear(), value.getUTCMonth(), 1));
      if (typeof value !== 'string') throw new Error(`Invalid date value: ${value}`);
      const trimmed = value.trim();
      if (/^\d{4}-\d{2}$/.test(trimmed)) {
        const [y, m] = trimmed.split('-').map(Number);
        return new Date(Date.UTC(y, m - 1, 1));
      }
      if (/^\d{4}-\d{2}-\d{2}$/.test(trimmed)) {
        const [y, m] = trimmed.split('-').map(Number);
        return new Date(Date.UTC(y, m - 1, 1));
      }
      const parsed = new Date(trimmed);
      if (!Number.isNaN(parsed.getTime())) return new Date(Date.UTC(parsed.getUTCFullYear(), parsed.getUTCMonth(), 1));
      throw new Error(`Could not parse month: ${value}`);
    }

    function monthKey(dateObj) {
      return `${dateObj.getUTCFullYear()}-${String(dateObj.getUTCMonth() + 1).padStart(2, '0')}`;
    }

    function lerp(a, b, t) { return a + (b - a) * t; }
    function easeInOutCubic(t) { return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2; }
    function formatBillions(value) {
      const rounded = value >= 100 ? Math.round(value) : value >= 10 ? Number(value.toFixed(1)) : Number(value.toFixed(3));
      return `$${rounded.toLocaleString('en-US')}B`;
    }
    function hexToRgba(hex, alpha) {
      const clean = String(hex).replace('#', '');
      const expanded = clean.length === 3 ? clean.split('').map(c => c + c).join('') : clean;
      const bigint = parseInt(expanded, 16);
      const r = (bigint >> 16) & 255;
      const g = (bigint >> 8) & 255;
      const b = bigint & 255;
      return `rgba(${r}, ${g}, ${b}, ${alpha})`;
    }

    async function waitForRender() {
      return new Promise(resolve => requestAnimationFrame(() => requestAnimationFrame(resolve)));
    }
    window.CryptoRaceExport = {
      frameCount: () => appState.frames.length,
      setFrame: async (index) => {
        currentIndex = Math.max(0, Math.min(appState.frames.length - 1, Number(index) || 0));
        frameAccumulator = 0;
        updateFrame(currentIndex);
        await waitForRender();
        return { index: currentIndex, date: dateEl.textContent };
      },
      play: () => { playing = true; },
      pause: () => { playing = false; },
      loadDataObject: async (obj) => {
        loadDatasetObject(obj, 'Injected data');
        await waitForRender();
      },
      getState: () => ({ index: currentIndex, date: dateEl.textContent, total: totalEl.textContent, dataset: appState.datasetName }),
      ready: true
    };
  </script>
