<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Crypto Market Cap Dominance Race · Data-Driven Monthly Renderer</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <style>
    :root {
      --bg: #08111f;
      --panel: #0d1728;
      --panel-2: #111e33;
      --text: #eef4ff;
      --muted: #8ea2c4;
      --accent: #49a3ff;
      --border: rgba(255,255,255,0.09);
      --shadow: 0 20px 60px rgba(0,0,0,0.35);
      --watermark: rgba(255,255,255,0.09);
      --danger: #ff6b6b;
      --success: #4dd4a6;
    }
    * { box-sizing: border-box; }
    html, body {
      margin: 0;
      min-height: 100%;
      background:
        radial-gradient(circle at top right, rgba(73,163,255,0.12), transparent 28%),
        radial-gradient(circle at bottom left, rgba(153,69,255,0.10), transparent 26%),
        linear-gradient(180deg, #07101c 0%, #0b1322 100%);
      color: var(--text);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    .wrap { max-width: 1460px; margin: 0 auto; padding: 24px; }
    .card {
      background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.015));
      border: 1px solid var(--border);
      border-radius: 24px;
      box-shadow: var(--shadow);
      overflow: hidden;
      backdrop-filter: blur(8px);
    }
    .importer {
      padding: 16px 24px;
      border-bottom: 1px solid var(--border);
      display: grid;
      grid-template-columns: 1fr auto auto;
      gap: 12px;
      align-items: center;
      background: linear-gradient(180deg, rgba(255,255,255,0.035), rgba(255,255,255,0.01));
    }
    .dataset-meta { min-width: 0; }
    .dataset-name {
      font-size: 15px; font-weight: 800; color: #f0f6ff; display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
    }
    .dataset-status {
      display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 999px;
      background: rgba(255,255,255,0.06); color: #cfe1ff; font-size: 12px; font-weight: 700;
    }
    .dataset-status.error { background: rgba(255,107,107,0.14); color: #ffd8d8; }
    .dataset-status.ok { background: rgba(77,212,166,0.14); color: #d5fff0; }
    .dataset-detail { font-size: 13px; color: var(--muted); margin-top: 5px; line-height: 1.35; }
    .dataset-actions { display: flex; gap: 10px; flex-wrap: wrap; justify-content: flex-end; }
    .file-input {
      position: relative; overflow: hidden; border-radius: 12px;
      border: 1px dashed rgba(255,255,255,0.18); background: rgba(255,255,255,0.04);
      padding: 11px 14px; font-size: 14px; font-weight: 700; cursor: pointer;
    }
    .file-input input {
      position: absolute; inset: 0; opacity: 0; cursor: pointer;
    }
    button, select {
      appearance: none; border: 1px solid rgba(255,255,255,0.08);
      background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.04));
      color: var(--text); border-radius: 12px; padding: 11px 15px; font-size: 14px; font-weight: 700; cursor: pointer;
    }
    button:hover, select:hover, .file-input:hover { border-color: rgba(255,255,255,0.16); }
    .header {
      display: grid; grid-template-columns: 1.2fr 1fr; gap: 20px; align-items: start;
      padding: 22px 24px 14px; border-bottom: 1px solid var(--border);
      background: linear-gradient(180deg, rgba(255,255,255,0.02), transparent);
    }
    .title-wrap h1 { margin: 0; font-size: clamp(28px, 3vw, 44px); line-height: 1.02; letter-spacing: -0.03em; }
    .subtitle { margin-top: 8px; color: var(--muted); font-size: 14px; }
    .meta {
      text-align: right; display: flex; flex-direction: column; gap: 6px; align-items: flex-end;
    }
    .date { font-size: clamp(28px, 3.2vw, 56px); font-weight: 800; letter-spacing: -0.04em; line-height: 1; }
    .total { font-size: clamp(16px, 1.5vw, 22px); color: #cfe1ff; font-weight: 700; }
    .bar-area { position: relative; padding: 18px 24px 12px; min-height: 860px; }
    #watermarkCanvas {
      position: absolute; inset: 18px 24px 12px 24px; width: calc(100% - 48px); height: calc(100% - 30px);
      pointer-events: none; z-index: 3;
    }
    .rows {
      position: relative; z-index: 2; display: flex; flex-direction: column; gap: 12px;
    }
    .row {
      position: relative; display: grid; grid-template-columns: 48px minmax(0, 1fr) 104px 170px; gap: 12px; align-items: center; min-height: 72px;
    }
    .rank {
      display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.05); border-radius: 14px; min-height: 72px;
    }
    .bar-shell {
      position: relative; min-height: 72px; border-radius: 18px; background: rgba(255,255,255,0.025);
      border: 1px solid rgba(255,255,255,0.05); overflow: hidden; display: flex; align-items: stretch;
    }
    .bar {
      position: relative; min-width: 1px; border-radius: 18px; display: flex; align-items: center;
      padding: 0 16px 0 12px; overflow: hidden; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.08);
    }
    .bar::after {
      content: ""; position: absolute; inset: 0;
      background: linear-gradient(90deg, rgba(255,255,255,0.10), rgba(255,255,255,0.00) 42%, rgba(0,0,0,0.12));
      pointer-events: none;
    }
    .bar-content {
      position: relative; z-index: 1; display: flex; align-items: center; justify-content: space-between; width: 100%; gap: 12px;
    }
    .coin-meta { display: flex; align-items: center; gap: 12px; min-width: 0; }
    .rank-logo-wrap { width: 34px; height: 34px; margin: 0 auto; }
    .rank-logo-wrap .logo-fallback, .rank-logo-wrap .logo-img { font-size: 10px; }
    .logo-wrap {
      position: relative; width: 34px; height: 34px; border-radius: 50%; flex: 0 0 34px;
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.22); overflow: hidden; background: rgba(255,255,255,0.16);
    }
    .logo-fallback, .logo-img {
      position: absolute; inset: 0; width: 100%; height: 100%; display: block; object-fit: cover; border-radius: 50%;
    }
    .logo-fallback {
      display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 800;
      color: rgba(255,255,255,0.95); text-transform: uppercase; letter-spacing: 0.04em;
    }
    .logo-img { opacity: 0; transition: opacity 0.22s ease; background: white; }
    .logo-img.loaded { opacity: 1; }
    .coin-name { min-width: 0; display: flex; flex-direction: column; gap: 1px; }
    .symbol {
      font-size: 22px; font-weight: 900; line-height: 1; letter-spacing: -0.04em; white-space: nowrap;
    }
    .label {
      font-size: 12px; opacity: 0.86; white-space: nowrap; text-overflow: ellipsis; overflow: hidden; max-width: 220px;
    }
    .share {
      flex: 0 0 auto; font-weight: 800; font-size: 16px; padding: 6px 10px; border-radius: 999px;
      background: rgba(0,0,0,0.20); color: rgba(255,255,255,0.98); backdrop-filter: blur(6px);
    }
    .value { font-size: 20px; font-weight: 800; color: #ecf4ff; text-align: right; letter-spacing: -0.03em; }
    .spark-wrap {
      height: 54px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);
      border-radius: 14px; padding: 4px 6px;
    }
    .spark-wrap canvas { width: 100% !important; height: 44px !important; display: block; }
    .annotation {
      margin: 2px 24px 16px; padding: 18px 18px 18px 20px; border-left: 4px solid var(--accent);
      background: linear-gradient(90deg, rgba(73,163,255,0.10), rgba(255,255,255,0.02));
      border-radius: 0 18px 18px 0; color: #e6f0ff; min-height: 80px; display: flex; flex-direction: column; justify-content: center; gap: 6px;
    }
    .annotation .event-date {
      font-size: 13px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.12em; font-weight: 700;
    }
    .annotation .event-text { font-size: clamp(16px, 1.25vw, 22px); line-height: 1.32; font-weight: 700; letter-spacing: -0.02em; }
    .controls { display: grid; grid-template-columns: auto 1fr auto; gap: 16px; padding: 0 24px 18px; align-items: center; }
    .buttons { display: flex; gap: 10px; flex-wrap: wrap; }
    .timeline { display: flex; align-items: center; gap: 12px; min-width: 0; }
    input[type="range"] { width: 100%; accent-color: var(--accent); cursor: pointer; }
    .speed-wrap { display: flex; align-items: center; gap: 8px; color: var(--muted); font-size: 13px; font-weight: 700; }
    .sources { padding: 0 24px 22px; color: var(--muted); font-size: 12px; letter-spacing: 0.01em; line-height: 1.4; }
    .social-overlay { display: none; }
    body.social-mode .wrap { max-width: 1120px; padding: 0; }
    body.social-mode .card { border-radius: 0; border: 0; min-height: 100vh; }
    body.social-mode .importer { display: none; }
    body.social-mode .header {
      grid-template-columns: 1fr; gap: 12px; padding: 34px 42px 16px;
    }
    body.social-mode .title-wrap h1 { font-size: clamp(42px, 5vw, 72px); }
    body.social-mode .subtitle { font-size: 18px; max-width: 72ch; }
    body.social-mode .meta { align-items: flex-start; text-align: left; }
    body.social-mode .date { font-size: clamp(58px, 8vw, 104px); }
    body.social-mode .total { font-size: clamp(22px, 2.4vw, 34px); }
    body.social-mode .bar-area { min-height: 910px; padding: 14px 42px 6px; }
    body.social-mode #watermarkCanvas {
      inset: 14px 42px 6px 42px; width: calc(100% - 84px); height: calc(100% - 20px);
    }
    body.social-mode .row { grid-template-columns: 58px minmax(0, 1fr) 124px 192px; min-height: 76px; }
    body.social-mode .rank { min-height: 76px; border-radius: 16px; }
    body.social-mode .bar-shell { min-height: 76px; }
    body.social-mode .symbol { font-size: 24px; }
    body.social-mode .label { font-size: 13px; }
    body.social-mode .value { font-size: 22px; }
    body.social-mode .spark-wrap { height: 60px; }
    body.social-mode .spark-wrap canvas { height: 50px !important; }
    body.social-mode .annotation {
      margin: 6px 42px 14px; min-height: 120px; padding: 18px 20px 18px 24px;
    }
    body.social-mode .annotation .event-text { font-size: clamp(22px, 2.1vw, 34px); }
    body.social-mode .controls, body.export-mode .controls { display: none; }
    body.social-mode .sources {
      padding: 0 42px 28px; font-size: 13px;
    }
    body.social-mode .social-overlay {
      pointer-events: none; display: flex; position: absolute; inset: 0; z-index: 4;
      justify-content: space-between; flex-direction: column;
    }
    .hook-badge {
      margin: 16px auto 0 0; max-width: 70%;
      padding: 18px 22px; border-radius: 22px;
      background: linear-gradient(180deg, rgba(5,11,21,0.72), rgba(5,11,21,0.38));
      border: 1px solid rgba(255,255,255,0.08); backdrop-filter: blur(12px);
      box-shadow: 0 18px 50px rgba(0,0,0,0.28);
    }
    .hook-kicker {
      text-transform: uppercase; letter-spacing: 0.14em; font-size: 13px; font-weight: 900; color: #8cc1ff;
      margin-bottom: 10px;
    }
    .hook-text {
      font-size: clamp(34px, 4vw, 58px); line-height: 0.98; font-weight: 900; letter-spacing: -0.05em;
      max-width: 10ch;
    }
    .hook-sub { margin-top: 12px; color: #d7e6ff; font-size: 16px; line-height: 1.35; max-width: 42ch; }
    .social-footer {
      align-self: flex-end; margin: 0 8px 12px 0; padding: 8px 14px; border-radius: 999px;
      font-size: 13px; font-weight: 900; letter-spacing: 0.06em; text-transform: uppercase;
      background: rgba(0,0,0,0.35); border: 1px solid rgba(255,255,255,0.08);
    }
    body.export-mode .importer { display: none; }
    .help-note { font-size: 12px; color: var(--muted); }
    @media (max-width: 1120px) {
      .importer, .header, .controls { grid-template-columns: 1fr; }
      .dataset-actions { justify-content: flex-start; }
      .meta { align-items: flex-start; text-align: left; }
      .row { grid-template-columns: 44px minmax(0, 1fr); }
      .value, .spark-wrap { display: none; }
      .bar-area { min-height: 900px; }
      #watermarkCanvas { inset: 18px 24px 12px 24px; }
      .speed-wrap { justify-content: flex-start; }
    }
    @media (max-width: 720px) {
      .wrap { padding: 12px; }
      .bar-area { padding: 14px 14px 10px; min-height: 840px; }
      #watermarkCanvas { inset: 14px 14px 10px 14px; width: calc(100% - 28px); }
      .importer, .annotation, .controls, .sources, .header { padding-left: 14px; padding-right: 14px; margin-left: 0; margin-right: 0; }
      .symbol { font-size: 19px; }
      .share { font-size: 13px; padding: 4px 8px; }
      .row { min-height: 64px; }
      .rank, .bar-shell { min-height: 64px; }
      .rank-logo-wrap { width: 34px; height: 34px; margin: 0 auto; }
      .rank-logo-wrap .logo-fallback, .rank-logo-wrap .logo-img { font-size: 10px; }
      .logo-wrap { width: 30px; height: 30px; flex-basis: 30px; }
    }
  </style>
</head>
